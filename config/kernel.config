# OnePlus Turbo 6 (SM8735) 主线内核配置
#
# 基于 Linux 6.13 ARM64 defconfig + 关键 Qualcomm 驱动
# 使用方法：复制到内核源码树根目录为 .config，然后编译
#
# 注意：SM8735 在 6.13 中没有独立的驱动支持。
# DTS 中使用的兼容字符串 (qcom,sun-*) 在 6.13 中不存在。
# 这是一个最小启动配置，后续需要：
#   1. 从 ACK 6.6 移植驱动 或
#   2. 使用支持 SM8735 的新内核版本

# ARM64 基础
CONFIG_ARM64=y
CONFIG_ARM64_SVE=y

# SoC 选择
CONFIG_ARCH_QCOM=y

# GCC 时钟控制器 (使用 SM8650 作为最接近的匹配)
CONFIG_SM_GCC_8650=y

# PINCTRL
CONFIG_PINCTRL=y
CONFIG_PINCTRL_MSM=y
CONFIG_PINCTRL_SM8650=y

# 中断控制器
CONFIG_QCOM_PDC=y

# RPMH 电源管理
CONFIG_QCOM_RPMH=y
CONFIG_QCOM_RPMHPD=y
CONFIG_QCOM_CLK_RPMH=y

# SMD/RPM 通信
CONFIG_QCOM_SMEM=y
CONFIG_QCOM_SMD_RPM=y

# 固件
CONFIG_QCOM_SCM=y

# 串口调试
CONFIG_SERIAL_QCOM_GENI=y
CONFIG_SERIAL_QCOM_GENI_CONSOLE=y
CONFIG_SERIAL_MSM=y
CONFIG_SERIAL_MSM_CONSOLE=y
CONFIG_SERIAL_EARLYCON=y

# Interconnect (总线互联)
CONFIG_INTERCONNECT_QCOM=y
CONFIG_INTERCONNECT_QCOM_BCM_VOTER=y
CONFIG_INTERCONNECT_QCOM_SM8650=y
CONFIG_INTERCONNECT_QCOM_SMD_RPM=y

# PMIC
CONFIG_QCOM_PMIC_GLINK=m

# 邮件控制器
CONFIG_QCOM_IPCC=y
CONFIG_MAILBOX=y

# GPIO
CONFIG_GPIOLIB=y
CONFIG_GPIO_SYSFS=y
CONFIG_PINCTRL=y

# 蓝牙 (后续启用)
# CONFIG_BT_QCOMSMD is not set

# WiFi (后续启用)
# CONFIG_WCN36XX is not set

# 显示 (后续启用)
# CONFIG_DRM_MSM is not set

# 音频 (后续启用)
# CONFIG_SND_SOC_QCOM is not set

# 存储
CONFIG_MMC=y
# CONFIG_MMC_SDHCI_MSM is not set (UFS 优先)
CONFIG_SCSI_UFSHCD=y
CONFIG_SCSI_UFS_QCOM=y

# USB
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_QCOM=y
CONFIG_TYPEC=y
CONFIG_TYPEC_TCPM=y
CONFIG_TYPEC_TCPCI=y

# 文件系统
CONFIG_EXT4_FS=y
CONFIG_VFAT_FS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# 网络
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IP_MULTICAST=y

# 杂项
CONFIG_OF=y
CONFIG_OF_OVERLAY=y
CONFIG_PRINTK=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
