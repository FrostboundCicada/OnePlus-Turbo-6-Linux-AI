# OnePlus Turbo 6 (SM8735) 主线内核配置
#
# 基于 Linux 7.1.1 ARM64 defconfig + 关键 Qualcomm 驱动
# 更新时间：2026-06-21
# 使用方法：GitHub Actions 云端编译（推荐）
#
# 注意：SM8735 (qcom,sun-*) 驱动仍未被上游化（截至 Linux 7.1.1）。
# 这是一个最小启动配置。后续需要：
#   1. 从 ACK 6.6.89 移植 sun-gcc、sun-tlmm 驱动（参见 patches/）
#   2. 或在主线加入 SM8735 支持后更新

# ARM64 基础
CONFIG_ARM64=y
CONFIG_ARM64_SVE=y

# SoC 选择
CONFIG_ARCH_QCOM=y

# GCC 时钟控制器
# SM8735 (Sun) 优先 — 通过 CI 工作流从 ACK 6.6.89 拉取
CONFIG_SM_GCC_SUN=y
# SM8650 作为 fallback（当 sun 驱动不可用时）
# CONFIG_SM_GCC_8650 is not set

# PINCTRL
CONFIG_PINCTRL=y
CONFIG_PINCTRL_MSM=y
# SM8735 (Sun) TLMM pinctrl — 通过 CI 工作流从 ACK 6.6.89 拉取
CONFIG_PINCTRL_SUN=y
# SM8650 作为 fallback
# CONFIG_PINCTRL_SM8650 is not set

# 中断控制器
CONFIG_QCOM_PDC=y

# RPMH 电源管理
CONFIG_QCOM_RPMH=y
CONFIG_QCOM_RPMHPD=y
CONFIG_QCOM_CLK_RPMH=y

# SMD/RPM 通信
CONFIG_QCOM_SMEM=y
CONFIG_QCOM_SMD_RPM=y

# 固件
CONFIG_QCOM_SCM=y

# 串口调试
CONFIG_SERIAL_QCOM_GENI=y
CONFIG_SERIAL_QCOM_GENI_CONSOLE=y
CONFIG_SERIAL_MSM=y
CONFIG_SERIAL_MSM_CONSOLE=y
CONFIG_SERIAL_EARLYCON=y

# Interconnect (总线互联)
CONFIG_INTERCONNECT_QCOM=y
CONFIG_INTERCONNECT_QCOM_BCM_VOTER=y
CONFIG_INTERCONNECT_QCOM_SM8650=y
CONFIG_INTERCONNECT_QCOM_SMD_RPM=y

# 存储
CONFIG_MMC=y
CONFIG_SCSI_UFSHCD=y
CONFIG_SCSI_UFS_QCOM=y
CONFIG_PHY_QCOM_UFS=y
CONFIG_PHY_QCOM_QMP=y

# USB
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_QCOM=y
CONFIG_TYPEC=y
CONFIG_TYPEC_TCPM=y
CONFIG_TYPEC_TCPCI=y

# PMIC
CONFIG_QCOM_PMIC_GLINK=m

# 邮件控制器
CONFIG_QCOM_IPCC=y
CONFIG_MAILBOX=y

# GPIO
CONFIG_GPIOLIB=y
CONFIG_GPIO_SYSFS=y

# 文件系统
CONFIG_EXT4_FS=y
CONFIG_VFAT_FS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# 网络
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IP_MULTICAST=y

# 杂项
CONFIG_OF=y
CONFIG_OF_OVERLAY=y
CONFIG_PRINTK=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# 蓝牙 (后续启用)
# CONFIG_BT_QCOMSMD is not set

# WiFi (后续启用)
# CONFIG_WCN36XX is not set

# 显示 (后续启用)
# CONFIG_DRM_MSM is not set

# 音频 (后续启用)
# CONFIG_SND_SOC_QCOM is not set
